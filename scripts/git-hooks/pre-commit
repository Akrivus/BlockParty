#!/bin/sh
set -e

if command -v pwsh >/dev/null 2>&1; then
    exec pwsh -NoProfile -ExecutionPolicy Bypass -File scripts/git-hooks/pre-commit.ps1
fi

if command -v powershell.exe >/dev/null 2>&1; then
    exec powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/git-hooks/pre-commit.ps1
fi

echo "PowerShell was not found; running Gradle directly."
exec ./gradlew phase1Compliance --no-daemon
